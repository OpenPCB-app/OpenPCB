# Multi-machine cloud-sync e2e spec credentials.
# Copy to .env.e2e (gitignored) with real values.
#
# Pro test account is documented in Cloud/RUNBOOK.md "E2E test account".
# Vault item: "OpenPCB / E2E test account".

E2E_CLOUD_API_URL=https://api.openpcb.app
E2E_CLOUD_SUPABASE_URL=https://supabase.openpcb.app
E2E_CLOUD_ANON_KEY=eyJ...replace-me...
E2E_CLOUD_TEST_EMAIL=e2e+demo@openpcb.app
E2E_CLOUD_TEST_PASSWORD=replace-me
