{
  "extends": "../../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "useDefineForClassFields": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "types": ["vite/client"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src", "vite.config.ts", "../contracts/**/*.ts"],
  "exclude": ["../backend/**", "../../src-react/**", "../../src-ts/**", "../../modules/**"]
}
