{
  "extends": "../../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "useDefineForClassFields": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "types": ["vite/client"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "src",
    "vite.config.ts",
    "../contracts/**/*.ts",
    "../../contracts/**/*.ts",
    "../../sdks/**/*.ts",
    "../../shared/domain/**/*.ts",
    "../../shared/rendering/types.ts"
  ],
  "exclude": ["../backend/**", "../../src-react/**", "../../src-ts/**", "../../modules/**", "**/*.test.ts", "**/*.test.tsx", "**/*.test.js", "**/*.test.jsx"]
}
