{
  "extends": "../../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "useDefineForClassFields": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "types": ["vite/client"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@modules/*": ["../../modules/*"],
      "@sdks/*": ["../../sdks/*"],
      "@shared/*": ["../../shared/*"]
    }
  },
  "include": [
    "src",
    "vite.config.ts",
    "../contracts/**/*.ts",
    "../../contracts/**/*.ts",
    "../../sdks/**/*.ts",
    "../../shared/domain/**/*.ts",
    "../../shared/rendering/**/*.ts",
    "../../shared/frontend/**/*.ts",
    "../../shared/frontend/**/*.tsx"
  ],
  "exclude": [
    "../backend/**",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.test.js",
    "**/*.test.jsx"
  ]
}
