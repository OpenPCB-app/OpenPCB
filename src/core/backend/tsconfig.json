{
  "extends": "../../../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "baseUrl": ".",
    "types": ["bun-types"],
    "typeRoots": ["./node_modules", "../../../node_modules"],
    "module": "esnext",
    "moduleResolution": "bundler"
  },
  "include": [
    "main.ts",
    "runtime.ts",
    "index.ts",
    "http/**/*.ts",
    "router/**/*.ts",
    "middleware/**/*.ts",
    "diagnostics/**/*.ts",
    "controllers/**/*.ts",
    "modules/**/*.ts",
    "contracts/**/*.ts",
    "../../contracts/**/*.ts",
    "../../sdks/**/*.ts",
    "../../shared/domain/**/*.ts",
    "../../shared/rendering/types.ts",
    "tests/**/*.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
