{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://OpenPCB.dev/schema/module.manifest.schema.json",
  "title": "Work Mind Module Manifest V2",
  "description": "Module manifest schema supporting both V1 and V2 module definitions",
  "type": "object",
  "additionalProperties": true,
  "required": ["id", "label", "version", "apiVersion", "namespace", "ui"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:[.-][a-z0-9]+)*$",
      "description": "Stable module identifier. Lowercase letters, digits, dashes, and dots are allowed."
    },
    "label": {
      "type": "string",
      "minLength": 1,
      "description": "Human-readable module name"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic version of the module"
    },
    "apiVersion": {
      "type": "integer",
      "minimum": 1,
      "maximum": 2,
      "description": "Module API version (1 for V1, 2 for V2)"
    },
    "namespace": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:\\.[a-z0-9]+)+$",
      "description": "Fully-qualified namespace used for bridge routing and event namespacing"
    },
    "kind": {
      "type": "string",
      "enum": ["space", "service", "integration", "widget", "system"],
      "default": "space",
      "description": "V2: Module type classification"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "default": [],
      "description": "V2: Searchable tags for module discovery"
    },
    "runner": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["inproc", "tauri", "deno", "worker"],
          "description": "TS runtime flavor"
        },
        "rust": {
          "type": "object",
          "properties": {
            "crate": {
              "type": "string",
              "description": "Rust crate name (optional)"
            },
            "enableEvents": {
              "type": "boolean",
              "default": false,
              "description": "Enable Rust event handlers"
            }
          }
        }
      }
    },
    "fs": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "root": {
          "type": "string",
          "description": "Module root under OpenPCB storage"
        },
        "scope": {
          "type": "string"
        },
        "permissions": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["read", "write", "watch"]
          },
          "description": "V2: FS permission flags"
        }
      }
    },
    "db": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "migrations": {
          "type": ["boolean", "string"]
        },
        "prefix": {
          "type": "string",
          "description": "Logical namespace for module tables/collections"
        }
      }
    },
    "ui": {
      "type": "object",
      "required": ["moduleEntry"],
      "additionalProperties": true,
      "properties": {
        "moduleEntry": {
          "type": "string",
          "description": "TS module definition path"
        },
        "primarySpace": {
          "type": "string",
          "description": "V2: React component for main space"
        },
        "widgets": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "slot", "entry"],
            "properties": {
              "id": {
                "type": "string",
                "description": "Widget identifier"
              },
              "slot": {
                "type": "string",
                "description": "Where widget can appear (sidebar, dashboard, etc.)"
              },
              "entry": {
                "type": "string",
                "description": "React entry for widget"
              }
            }
          },
          "description": "V2: Widget definitions"
        },
        "registerAsSpaceInTopBar": {
          "type": "boolean",
          "default": false,
          "description": "Show module in top navigation bar"
        },
        "routes": {
          "type": "array",
          "items": { "type": "object" },
          "default": []
        }
      }
    },
    "dependsOn": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Dependency module id"
          },
          "minVersion": {
            "type": "string",
            "pattern": "^(>=|>|=)?\\d+\\.\\d+\\.\\d+$",
            "description": "Minimum version constraint"
          },
          "optional": {
            "type": "boolean",
            "default": false,
            "description": "Soft dependency (module works without it)"
          }
        }
      },
      "default": [],
      "description": "V2: Module dependencies"
    },
    "exports": {
      "type": "object",
      "properties": {
        "services": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "kind"],
            "properties": {
              "id": {
                "type": "string",
                "description": "Service identifier (e.g., 'rag.search')"
              },
              "kind": {
                "type": "string",
                "enum": ["http", "bridge", "local"],
                "description": "Implementation backend"
              },
              "description": {
                "type": "string"
              }
            }
          },
          "description": "V2: Services offered to other modules"
        },
        "widgets": {
          "type": "array",
          "items": { "type": "string" },
          "description": "V2: Widget ids that can be embedded elsewhere"
        }
      },
      "description": "V2: Module exports"
    },
    "defaultPinned": {
      "type": "boolean",
      "default": false,
      "description": "V2: Pinned in sidebar/topbar by default"
    },
    "decorates": {
      "type": "array",
      "items": { "type": "string" },
      "default": [],
      "description": "V1: Legacy decorator references"
    },
    "overrides": {
      "type": "array",
      "items": { "type": "string" },
      "default": [],
      "description": "V1: Legacy override references"
    },
    "dependencies": {
      "type": "array",
      "items": { "type": "string" },
      "default": [],
      "description": "V1: Legacy simple dependency list (use dependsOn for V2)"
    }
  }
}
