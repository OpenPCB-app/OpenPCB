{
  "id": "ai-service",
  "label": "Ai Service",
  "version": "0.1.0",
  "apiVersion": 2,
  "namespace": "space.aiservice",
  "kind": "space",
  "tags": [],
  "runner": {
    "mode": "inproc",
    "rust": {
      "crate": "module_ai_service",
      "enableEvents": false
    }
  },
  "fs": {
    "root": "/modules/ai-service",
    "permissions": [
      "read",
      "write"
    ]
  },
  "db": {
    "prefix": "ai_service",
    "migrations": true,
    "rawAccess": true
  },
  "coreCapabilities": [
    "projects",
    "contentEditor",
    "toolRegistry"
  ],
  "ui": {
    "moduleEntry": "ts/module.ts",
    "primarySpace": "react/Space.tsx",
    "registerAsSpaceInTopBar": true
  },
  "dependsOn": [],
  "exports": {
    "services": [],
    "widgets": []
  },
  "defaultPinned": false
}
