{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["OpenPCB"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:window:allow-start-dragging",
    "opener:default",
    "log:default",
    "os:default",
    "sentry:default",
    "shell:allow-spawn",
    "shell:allow-stdin-write",
    "shell:allow-kill",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "bun-backend",
          "sidecar": true,
          "args": false
        },
        {
          "name": "bun",
          "cmd": "",
          "args": [
            "--watch",
            {
              "validator": ".*[\\\\/]src-ts[\\\\/]src[\\\\/]main\\.ts"
            }
          ]
        }
      ]
    }
  ]
}
