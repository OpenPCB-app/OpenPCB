{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpenPCB",
  "version": "0.1.0",
  "identifier": "com.openpcb.app",
  "build": {
    "beforeDevCommand": "npm run dev:frontend",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build:frontend",
    "frontendDist": "../src-react/dist"
  },
  "app": {
    "windows": [
      {
        "label": "OpenPCB",
        "title": "OpenPCB",
        "width": 1200,
        "height": 600,
        "resizable": true,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:* ws://127.0.0.1:*; script-src 'self'; style-src 'self' 'unsafe-inline'"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDJDQkEyREQxNzAwMTY3NDkKUldSSlp3RncwUzI2TE1XWmFUNnU3bGdVWjd3YjVoZStSeEh6UmRNWnFZeFVrUDRwOGlCZERtZU8K",
      "endpoints": [
        "https://raw.githubusercontent.com/andrejvysny/OpenPCBReleases/main/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "externalBin": ["../bin/bun-backend"],
    "resources": ["../src-ts/drizzle/migrations/**/*"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
