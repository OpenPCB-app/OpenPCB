{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "types": ["node"],
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "tailwindcss": ["../node_modules/tailwindcss/dist/lib.d.mts"]
    }
  },
  "include": ["vite.config.ts", "tailwind.config.ts"]
}
