{
  "name": "openpcb",
  "private": true,
  "type": "module",
  "workspaces": [
    "src-react"
  ],
  "scripts": {
    "setup": "npm install && (cd src-ts && bun install) && npm run bun:compile && npm run gen",
    "dev": "concurrently --kill-others-on-fail --names backend,frontend --prefix-colors blue,green \"npm run dev:backend\" \"npx wait-on tcp:127.0.0.1:3000 && npm run dev:frontend\"",
    "dev:desktop": "npm run tauri dev",
    "dev:browser": "concurrently --kill-others-on-fail --names backend,frontend --prefix-colors blue,green \"npm run dev:backend\" \"npx wait-on tcp:127.0.0.1:3000 && npx playwright test --ui\"",
    "dev:backend": "cd src-ts && PORT=3000 NODE_ENV=development OPENPCB_ALLOW_UNAUTHENTICATED_API=true bun src/main.ts",
    "dev:with-feedback": "npm run dev:feedback & npm run tauri dev",
    "dev:feedback": "cd backend && DATA_DIR=\"$HOME/Library/Caches/OpenPCB/feedback\" PORT=3001 bun src/server.ts",
    "tauri": "tauri",
    "dev:frontend": "npm run dev --workspace src-react",
    "build": "npm run bun:compile && npm run build:frontend && npm run tauri build",
    "build:frontend": "npm run gen && tsc -b && npm run build --workspace src-react",
    "build:tauri": "npm run tauri build",
    "bun:compile": "bun scripts/compile-bun-sidecar.ts",
    "typecheck": "npm run gen && tsc -b",
    "module": "bun scripts/module-cli.ts",
    "module:create": "bun scripts/module-cli.ts --create",
    "module:validate": "bun scripts/module-cli.ts --validate",
    "module:codegen": "bun scripts/module-cli.ts --codegen",
    "gen:bindings": "cargo run --manifest-path src-tauri/Cargo.toml --bin export_bindings",
    "bindings:generate": "npm run types:generate",
    "bridge:generate": "npm run scripts:build && bun scripts/module-cli.ts --codegen-bridge",
    "modules:generate": "npm run scripts:build && bun scripts/module-cli.ts --codegen-registry",
    "modules:validate": "npm run scripts:build && bun scripts/module-cli.ts --validate",
    "types:generate": "npm run scripts:build && bun scripts/module-cli.ts --codegen-types",
    "scripts:build": "bun run --bun tsc -p tsconfig.scripts.json",
    "sdk:generate": "npm run scripts:build && bun scripts/module-cli.ts --codegen-sdk",
    "gen:openapi": "bun scripts/generate-openapi.ts",
    "gen:sdk:orval": "orval",
    "gen": "npm run modules:generate && npm run bindings:generate && npm run bridge:generate && npm run sdk:generate && npm run gen:openapi && npm run gen:sdk:orval",
    "gen:check": "npm run gen && git diff --quiet -- src-react/src/generated src-ts/shared/generated openapi.json || (echo 'Codegen not committed. Run npm run gen and commit generated files.' && git --no-pager diff -- src-react/src/generated src-ts/shared/generated openapi.json && exit 1)",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun src-ts/scripts/run-migrations.ts",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:check": "drizzle-kit check",
    "test:ts": "cd src-ts && bun test src test tests",
    "test:ts:watch": "cd src-ts && bun test src test tests --watch",
    "test:react": "cd src-react && npx vitest run",
    "test:react:watch": "cd src-react && npx vitest",
    "test:e2e": "playwright test",
    "lint": "npm run lint --workspace src-react --if-present"
  },
  "devDependencies": {
    "@iarna/toml": "^2.2.5",
    "@inquirer/prompts": "^8.0.2",
    "@playwright/test": "^1.0.0",
    "@tauri-apps/cli": "^2.7.0",
    "@types/bun": "^1.3.5",
    "ajv": "^8.17.1",
    "bun-types": "^1.3.5",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.8",
    "orval": "^7.17.0",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "wait-on": "^9.0.4"
  },
  "version": "0.1.0",
  "packageManager": "npm@10.9.2",
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^8.2.0",
    "@tauri-apps/plugin-clipboard-manager": "^2.3.2",
    "@tauri-apps/plugin-http": "^2.5.4",
    "@tauri-apps/plugin-log": "^2.7.1",
    "@tauri-apps/plugin-os": "^2.3.2",
    "@tauri-apps/plugin-shell": "^2",
    "@tauri-apps/plugin-stronghold": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.0",
    "@tiptap/extension-drag-handle-react": "^3.15.3",
    "@tiptap/extension-image": "^3.15.3",
    "@tiptap/extension-link": "^3.15.3",
    "@tiptap/extension-placeholder": "^3.15.3",
    "@tiptap/extension-subscript": "^3.19.0",
    "@tiptap/extension-superscript": "^3.19.0",
    "@tiptap/extension-task-item": "^3.15.3",
    "@tiptap/extension-task-list": "^3.15.3",
    "@tiptap/extension-text-align": "^3.19.0",
    "@tiptap/pm": "^3.15.3",
    "@tiptap/react": "^3.15.3",
    "@tiptap/starter-kit": "^3.15.3",
    "@tiptap/suggestion": "^3.15.3",
    "drizzle-orm": "^0.45.1",
    "pdf-lib": "^1.17.1",
    "sharp": "^0.34.3",
    "tauri-plugin-sentry-api": "^0.5.0",
    "tippy.js": "^6.3.7",
    "uuid": "^11.0.3",
    "zod": "^4.1.13"
  }
}
