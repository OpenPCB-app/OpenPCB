# OpenPCB Environment Configuration
# Copy this file to .env and configure for your environment

# Database Configuration
# Path to SQLite database file
# Default: {APP_DATA_DIR}/OpenPCB.db or ./data/OpenPCB.db
DB_FILE_PATH=./data/OpenPCB.db

# Application Data Directory
# Set by Rust layer at runtime, can be overridden for testing
# APP_DATA_DIR=

# Application Log Directory
# Set by Rust layer at runtime, can be overridden for testing
# APP_LOG_DIR=

# Server Configuration
# Bun backend HTTP server port (dynamically assigned by default)
# PORT=3000

# Environment Mode
# NODE_ENV=development

# Feedback Backend Configuration
# URL for the feedback collection API (default: http://localhost:3000/v1/feedback)
# VITE_FEEDBACK_API_URL=http://localhost:3000/v1/feedback
# API key for authenticating with the feedback/analytics backend
# Must match the API_KEY configured on the backend server
# VITE_FEEDBACK_API_KEY=your-secret-api-key
